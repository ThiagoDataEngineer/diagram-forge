# ── Anthropic (required) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Modelo Claude (opcional — atualizar quando sair versão nova) ───────────────
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Lightning — Managed Mode (l402kit.com) ───────────────────
# Lightning Address onde você recebe os sats (público, pode commitar)
LIGHTNING_ADDRESS=pinkfalcon21@primal.net

# ── Lightning — Blink (soberano, sem fee) ────────────────────
# Get API key: Blink app → Settings → API → Generate key
# Get wallet ID: query POST https://api.blink.sv/graphql
#   {"query":"{ me { defaultAccount { wallets { id walletCurrency } } } }"}
BLINK_API_KEY=
BLINK_WALLET_ID=

# ── Lightning — LNbits (alternative) ─────────────────────────
LNBITS_URL=
LNBITS_API_KEY=

# ── L402 macaroon signing secret (generate with: openssl rand -hex 32) ──
MACAROON_SECRET=change-me-to-a-random-32-byte-hex-string

# ── Stripe (optional — omit to use Lightning only) ────────
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get from: stripe listen --forward-to localhost:3000/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Server ────────────────────────────────────────────────
PORT=3000
