{
  "name": "diagram-forge-action",
  "version": "1.0.0",
  "description": "GitHub Action for Diagram Forge architecture analysis",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@actions/core --external:@actions/github",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
