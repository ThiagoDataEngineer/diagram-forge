{
  "name": "diagram-forge",
  "version": "0.1.0",
  "description": "AI-powered living architecture diagram generator — paid via Lightning L402",
  "main": "dist/cli.js",
  "bin": {
    "diagram-forge": "dist/cli.js"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "analyze": "tsx src/cli.ts",
    "mcp": "tsx src/mcp/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run src/test/unit",
    "test:smoke": "vitest run src/test/smoke.test.ts",
    "test:e2e": "vitest run src/test/e2e.test.ts",
    "test:blink": "vitest run src/test/integration/blink.test.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "architecture",
    "diagram",
    "ai",
    "claude",
    "lightning"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.94.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.105.3",
    "@types/node": "^25.6.0",
    "canvas": "^3.2.3",
    "dagre": "^0.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gifsicle": "^7.0.1",
    "l402-kit": "^1.8.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.43.0",
    "qrcode": "^1.5.4",
    "stripe": "^22.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.5",
    "gif-encoder-2": "^1.0.5",
    "jimp": "^1.6.1",
    "vitest": "^4.1.5"
  }
}
